<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".PersegiPanjang">

    <TextView
        android:id="@+id/persegiPanjang"
        android:textAlignment="center"
        android:layout_margin="20dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:text="Persegi Panjang"
        android:textSize="40sp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>

    <EditText
        android:layout_margin="20dp"
        app:layout_constraintTop_toBottomOf="@id/persegiPanjang"
        app:layout_constraintStart_toStartOf="parent"
        android:textSize="35dp"
        android:hint="panjang"
        android:id="@+id/edpanjang"
        android:layout_width="150dp"
        android:layout_height="wrap_content"/>

    <EditText
        android:layout_margin="20dp"
        android:textSize="35dp"
        app:layout_constraintEnd_toEndOf="parent"
        android:id="@+id/edlebar"
        android:hint="lebar"
        app:layout_constraintTop_toBottomOf="@id/persegiPanjang"
        android:layout_width="150dp"
        android:layout_height="wrap_content"/>

    <Button
        android:layout_margin="30dp"
        app:layout_constraintTop_toBottomOf="@id/edpanjang"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:text="luas"
        android:id="@+id/btnluas"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <Button
        android:text="kell"
        android:layout_margin="20dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btnluas"
        android:id="@+id/btnkell"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <TextView
        android:textSize="50sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:text="Hasil"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>
</androidx.constraintlayout.widget.ConstraintLayout>