<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".LoginInsta">

    <ImageView
        android:id="@+id/imgLogo"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:src="@drawable/insta2"
        app:layout_constraintTop_toTopOf="parent"
         app:layout_constraintBottom_toTopOf="@id/edUsn"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="100dp"/>

    <EditText
        android:textColorHint="@color/black"
        android:layout_marginStart="10dp"
        android:layout_marginEnd="10dp"
        android:id="@+id/edUsn"
        android:background="@drawable/edittext_abu"
        android:layout_marginTop="120dp"
        android:hint="Nama pengguna, email, atau nomor ponsel"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/imgLogo"
        android:layout_width="0dp"
        android:layout_height="55dp"/>

    <EditText
        android:textColorHint="@color/black"
        android:layout_marginEnd="10dp"
        android:layout_marginStart="10dp"
        android:layout_marginTop="20dp"
        android:id="@+id/edPass2"
        android:background="@drawable/edittext_abu"
        android:hint="Kata Sandi"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/edUsn"
        android:layout_width="0dp"
        android:layout_height="55dp"/>

    <Button
        android:id="@+id/btnLog"
        android:textColorHint="@color/white"
        android:hint="Login"
        android:layout_marginEnd="20dp"
        android:layout_marginStart="20dp"
        android:backgroundTint="#1877F2"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toBottomOf="@+id/edPass2"
        android:layout_width="0dp"
        android:layout_height="55dp"/>

    <TextView
        android:id="@+id/tvLupa"
        android:textColor="@color/black"
        android:text="Lupa kata sandi?"
        android:textSize="18sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/btnLog"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <Button
        android:id="@+id/btnBuat"
        android:layout_width="0dp"
        android:layout_height="50dp"
        android:text="Buat akun baru"
        android:textColor="@android:color/holo_blue_dark"
        app:strokeWidth="1dp"
        app:strokeColor="#0095F6"
        android:backgroundTint="@android:color/transparent"
        android:layout_marginTop="100dp"
        app:layout_constraintTop_toBottomOf="@id/tvLupa"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <ImageView
        android:id="@+id/imageView"
        android:layout_width="60sp"
        android:layout_height="60sp"
        android:layout_marginTop="20sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btnBuat"
        app:srcCompat="@drawable/meta" />



  </androidx.constraintlayout.widget.ConstraintLayout>